@model FlightReservation.Models.Flight
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Create Flight";
    var airports = ViewData["Airports"] as SelectList;
}

<h2>Create Flight</h2>

<form asp-action="Create" method="post" class="mt-4">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="form-group mb-3">
        <label asp-for="FlightNumber"></label>
        <input asp-for="FlightNumber" class="form-control"/>
    </div>

    <div class="form-group mb-3">
        <label>From Airport</label>
        <select asp-for="FromAirportId" asp-items="airports" class="form-control">
            <option value="">Select...</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>To Airport</label>
        <select asp-for="ToAirportId" asp-items="airports" class="form-control">
            <option value="">Select...</option>
        </select>
    </div>

    <div class="row mb-3">
        <div class="col">
            <label>Departure</label>
            <input asp-for="DepartureTime" type="datetime-local" class="form-control"/>
        </div>

        <div class="col">
            <label>Arrival</label>
            <input asp-for="ArrivalTime" type="datetime-local" class="form-control"/>
        </div>
    </div>

    <div class="form-group mb-3">
        <label>Price (₺)</label>
        <input asp-for="Price" type="number" class="form-control"/>
    </div>

    <button class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
